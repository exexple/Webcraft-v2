{
  "buildCommand": "cd apps/frontend && npm run build",
  "outputDirectory": "apps/frontend/dist",
  "env": {
    "VITE_FIREBASE_API_KEY": "@webcraft_firebase_api_key",
    "VITE_FIREBASE_AUTH_DOMAIN": "@webcraft_firebase_auth_domain",
    "VITE_FIREBASE_PROJECT_ID": "@webcraft_firebase_project_id",
    "VITE_FIREBASE_STORAGE_BUCKET": "@webcraft_firebase_storage_bucket",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "@webcraft_firebase_messaging_sender_id",
    "VITE_FIREBASE_APP_ID": "@webcraft_firebase_app_id",
    "VITE_API_BASE_URL": "@webcraft_api_base_url"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
